{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "WebSearch",
      "mcp__*",
      "Read(/Users/sethkravitz/.fieldtheory/handoffs/*)",
      "Write(/Users/sethkravitz/.fieldtheory/handoffs/*)",
      "Edit(/Users/sethkravitz/.fieldtheory/handoffs/*)",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(*sudo *)",
      "Bash(*rm -rf *)",
      "Bash(*rm -rf)",
      "Bash(*rm -fr *)",
      "Bash(*rm -fr)",
      "Bash(*rm -Rf *)",
      "Bash(*rm -Rf)",
      "Bash(*rm -RF *)",
      "Bash(*rm -RF)",
      "Bash(*rm -r *)",
      "Bash(*rm -r)",
      "Bash(*rm --recursive*)",
      "Bash(*mkfs*)",
      "Bash(*mke2fs*)",
      "Bash(*newfs*)",
      "Bash(*wipefs*)",
      "Bash(dd *)",
      "Bash(* dd *)",
      "Bash(*truncate *)",
      "Bash(*shred *)",
      "Bash(*| bash)",
      "Bash(*| bash *)",
      "Bash(*|bash)",
      "Bash(*|bash *)",
      "Bash(*| sh)",
      "Bash(*| sh *)",
      "Bash(*|sh)",
      "Bash(*|sh *)",
      "Bash(*| zsh)",
      "Bash(*| zsh *)",
      "Bash(*|zsh)",
      "Bash(*|zsh *)",
      "Bash(*git clean*-f*)",
      "Bash(*git push*--mirror*)",
      "Bash(*docker system prune*)",
      "Bash(*docker volume rm*)",
      "Bash(*docker volume prune*)"
    ],
    "ask": [
      "Bash(*npm install*)",
      "Bash(*npm i *)",
      "Bash(*npm i)",
      "Bash(*npm ci *)",
      "Bash(*npm ci)",
      "Bash(*yarn add *)",
      "Bash(*yarn install*)",
      "Bash(*pnpm add *)",
      "Bash(*pnpm install*)",
      "Bash(*bun add *)",
      "Bash(*bun install*)",
      "Bash(*pip install *)",
      "Bash(*pip3 install *)",
      "Bash(*brew install *)",
      "Bash(*cargo install *)",
      "Bash(*go install *)",
      "Bash(*git push*--force*)",
      "Bash(*git push* -f*)",
      "Bash(*git reset*--hard*)",
      "Bash(*chmod*777*)",
      "Bash(*chmod*000*)",
      "Bash(*chown *)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "/Users/sethkravitz/Code/prompt-studio/src/app/api/uploads",
      "/Users/sethkravitz/.claude",
      "/tmp",
      "/Users/sethkravitz/Code"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == \"Bash\"",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dangerous-command-blocker.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"--no-verify\"",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\necho '[Hook] BLOCKED: --no-verify is not allowed' >&2\necho '[Hook] Fix the pre-commit issue instead of skipping hooks' >&2\nexit 2"
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"\\\\|\\\\s*(\\/usr\\/bin\\/|\\/bin\\/)?(bash|sh|zsh)\"",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\necho '[Hook] BLOCKED: Piping to shell interpreter is not allowed' >&2\necho '[Hook] Download the script first, review it, then run it separately' >&2\nexit 2"
          }
        ]
      },
      {
        "matcher": "tool == \"Edit\" || tool == \"Write\"",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/strategic-compact/suggest-compact.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/Users/sethkravitz/.claude/fieldtheory-read-permission-hook.py\""
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/Users/sethkravitz/.claude/fieldtheory-librarian-pretool.py\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh pre",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "tool == \"Edit\" && tool_input.file_path matches \"\\\\.(ts|tsx|js|jsx)$\"",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\ninput=$(cat)\nfile_path=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"')\nif [ -n \"$file_path\" ] && [ -f \"$file_path\" ]; then\n  npx prettier --write \"$file_path\" 2>/dev/null || true\nfi\necho \"$input\"",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "tool == \"Edit\" && tool_input.file_path matches \"\\\\.(ts|tsx)$\"",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\ninput=$(cat)\nfile_path=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"')\nif [ -n \"$file_path\" ] && [ -f \"$file_path\" ]; then\n  dir=$(dirname \"$file_path\")\n  project_root=\"$dir\"\n  while [ \"$project_root\" != \"/\" ] && [ ! -f \"$project_root/package.json\" ]; do\n    project_root=$(dirname \"$project_root\")\n  done\n  if [ -f \"$project_root/tsconfig.json\" ]; then\n    cd \"$project_root\" && npx tsc --noEmit --pretty false 2>&1 | grep \"$file_path\" | head -5 >&2 || true\n  fi\nfi\necho \"$input\"",
            "timeout": 30000
          }
        ]
      },
      {
        "matcher": "tool == \"Edit\" && tool_input.file_path matches \"\\\\.(ts|tsx|js|jsx)$\"",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\ninput=$(cat)\nfile_path=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"')\nif [ -n \"$file_path\" ] && [ -f \"$file_path\" ]; then\n  console_logs=$(grep -n \"console\\.log\" \"$file_path\" 2>/dev/null || true)\n  if [ -n \"$console_logs\" ]; then\n    echo \"[Hook] WARNING: console.log found in $file_path\" >&2\n    echo \"$console_logs\" | head -3 >&2\n  fi\nfi\necho \"$input\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh post",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/compaction/pre-compact.py",
            "timeout": 15000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-persistence/session-start.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-router/index-skills.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/compaction/compact-recovery.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\nif git rev-parse --git-dir > /dev/null 2>&1; then\n  modified=$(git diff --name-only HEAD 2>/dev/null | grep -E '\\.(ts|tsx|js|jsx)$' || true)\n  if [ -n \"$modified\" ]; then\n    has_console=false\n    while IFS= read -r file; do\n      if [ -f \"$file\" ] && grep -q \"console\\.log\" \"$file\" 2>/dev/null; then\n        echo \"[Hook] WARNING: console.log in $file\" >&2\n        has_console=true\n      fi\n    done <<< \"$modified\"\n    if [ \"$has_console\" = true ]; then\n      echo \"[Hook] Remove console.log before committing\" >&2\n    fi\n  fi\nfi",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-persistence/session-end.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-router/audit-skills.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/Users/sethkravitz/.claude/fieldtheory-librarian-hook.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-router/route-skills.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "local-plugins": {
      "source": {
        "source": "directory",
        "path": "/Users/sethkravitz/.claude/plugins"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/hooks/compaction/context-monitor.sh"
  }
}